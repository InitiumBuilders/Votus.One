# Votus.One Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Vercel KV (Upstash Redis) — get these from your Vercel project settings
KV_REST_API_URL=https://your-upstash-instance.upstash.io
KV_REST_API_TOKEN=your_kv_token_here
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token_here

# Admin key for protected operations
VOTUS_ADMIN_KEY=your_secret_admin_key_here
